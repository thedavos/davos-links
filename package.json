{
  "name": "davos-links",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev",
    "generate-routes": "tsr generate",
    "typecheck": "tsc --noEmit",
    "build": "vite build && pnpm typecheck",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "deploy": "pnpm build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply davos-links-db",
    "db:migrate:local": "wrangler d1 migrations apply davos-links-db --local",
    "ui:detect": "npx impeccable detect src/"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.545.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.10",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.70.0"
  }
}
